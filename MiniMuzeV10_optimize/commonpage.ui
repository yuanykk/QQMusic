   <item>
    <widget class="QListWidget" name="pageMusicList">
     <property name="styleSheet">
      <string notr="true">/* 默认状态：无虚线框 */
#pageMusicList::item {
    outline: none;
}

/* 选中状态：无虚线框 */
#pageMusicList::item:selected {
    background-color: #EFEFEF;
    outline: none;
}

/* 选中且鼠标悬停时：移除虚线框（或保持无框） */
#pageMusicList::selected:hover {
    background-color: #E0E0E0;  /* 悬停时的背景色 */
    outline: none;
	border:none;
}

/* 选中且未悬停时（鼠标移开后）：显示虚线框 */
#pageMusicList::selected:!hover {
    /* 或者使用 outline: auto; 使用系统默认样式 */
    outline: none;
	border:none;
}




/* ===== 完全自定义滚动条，无多余线条 ===== */

/* QListWidget 本身 */
#pageMusicList {
    border: none;
    background-color: white;
}

/* 垂直滚动条整体 */
QScrollBar:vertical {
    width: 10px;
    background: #F0F0F0;
    border: none;
    margin: 0px;
    padding: 0px;
}

/* 滑块 - 灰色 */
QScrollBar::handle:vertical {
    background-color: #C0C0C0;  /* 银色/灰色 */
    border-radius: 5px;
    min-height: 30px;
    border: none;
    margin: 0px;
}

/* 滑块悬停 - 深灰色 */
QScrollBar::handle:vertical:hover {
    background-color: #A0A0A0;  /* 深灰色 */
}

/* 滑块按下 - 更深的灰色 */
QScrollBar::handle:vertical:pressed {
    background-color: #808080;  /* 中灰色 */
}

/* 完全隐藏上下箭头区域 */
QScrollBar::sub-line:vertical,
QScrollBar::add-line:vertical {
    background: transparent;
    border: none;
    height: 0px;
    width: 0px;
}

/* 隐藏箭头图标 */
QScrollBar::up-arrow:vertical,
QScrollBar::down-arrow:vertical {
    background: none;
    width: 0px;
    height: 0px;
}

/* 滑块轨道区域背景统一 */
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: #F0F0F0;
    border: none;
}

/* 滚动条角落（如果存在水平滚动条） */
QScrollBar:corner {
    background: #F0F0F0;
    border: none;
}</string>
